#!/usr/bin/env sh
set -e

# Auto-fix tree-shaking artifacts if any core source files are staged
if git diff --cached --name-only | grep -q '^packages/dev/core/src/'; then
  npm run update:manifest
  node scripts/treeshaking/syncSideEffects.mjs
  npm run generate:pure-barrels -- --no-format
  npm run generate:side-effect-stubs
  git add scripts/treeshaking/side-effects-manifest.json
  git add packages/public/@babylonjs/core/package.json
  find packages/dev/core/src -name 'pure.ts' -print0 | xargs -0 git add --
  git diff --name-only -- packages/dev/core/src | grep '\.pure\.ts$' | while IFS= read -r file; do
    git add "$file"
  done
fi

npm run precommit
