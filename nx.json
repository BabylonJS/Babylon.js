{
    "npmScope": "babylonjs",
    "tasksRunnerOptions": {
        "default": {
            "runner": "nx/tasks-runners/default",
            "options": {
                "cacheableOperations": ["build", "test", "lint", "package", "prepare"]
            }
        }
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"]
        },
        "prepare": {
            "dependsOn": ["^prepare"]
        },
        "package": {
            "dependsOn": ["^package"]
        }
    },
    "affected": {
        "defaultBase": "main"
    },
    "analytics": false
}
