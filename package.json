{
    "name": "@babylonjs/root",
    "version": "1.0.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/BabylonJS/bjs-monorepo"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babylonjs/lite": "1.14.0",
        "@dev/build-tools": "^1.0.0",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "1.57.0",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-url": "^8.0.2",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@typescript-eslint/utils": "^8.58.2",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.3",
        "@vitest/eslint-plugin": "^1.6.14",
        "ajv": "~8.18.0",
        "chokidar": "~3.6.0",
        "dotenv": "~16.0.0",
        "es-check": "^7.1.1",
        "esbuild": "^0.28.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-azure-devops": "^1.2.0",
        "eslint-plugin-github": "^6.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.7.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-tsdoc": "^0.5.0",
        "glob": "^13.0.6",
        "globals": "^16.0.0",
        "jsdom": "^27.4.0",
        "lint-staged": "^16.2.7",
        "nx": "^22.5.4",
        "prettier": "^3.0.3",
        "rimraf": "^6.1.3",
        "rollup-plugin-dts": "^6.4.1",
        "rollup-plugin-postcss": "^4.0.2",
        "serialize-javascript": "7.0.5",
        "ts-node": "~10.9.0",
        "tslib": "^2.4.0",
        "typedoc": "^0.28.16",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "8.1.3",
        "vitest": "^4.1.3"
    },
    "workspaces": [
        "packages/**/*"
    ],
    "scripts": {
        "build:dev": "npm run build:assets && npm run build:source && npm run build:declaration -w @tools/babylon-server",
        "build:source": "tsc -b ./tsconfig.devpackages.json",
        "build:source:smart-filters": "npm run build:assets:smart-filters && tsc -b ./tsconfig.smartFilters.json",
        "build:umd": "npm run build:umd:libs && npm run build:umd:tools",
        "build:umd:libs": "nx run-many --outputStyle=static --target=build --parallel --maxParallel=6 --projects=babylonjs,babylonjs-gui,babylonjs-loaders,babylonjs-materials,babylonjs-serializers,babylonjs-post-process,babylonjs-procedural-textures,babylonjs-ktx2decoder,babylonjs-accessibility,babylonjs-addons",
        "build:umd:tools": "nx run-many --outputStyle=static --target=build --parallel --maxParallel=2 --projects=babylonjs-inspector-legacy,babylonjs-node-editor,babylonjs-node-geometry-editor,babylonjs-node-render-graph-editor,babylonjs-node-particle-editor,babylonjs-gui-editor,babylonjs-inspector,create-babylonjs",
        "downlevel:native-scripts": "node ./scripts/downlevelNativeScripts.mjs",
        "build:es6": "npm run build:assets:smart-filters && npm run build:es6:libs && npm run build:es6:tools && npm run check:treeshaking-all",
        "build:es6:libs": "nx run-many --outputStyle=static --target=build --parallel --maxParallel=6 --projects=@babylonjs/core,@babylonjs/gui,@babylonjs/loaders,@babylonjs/materials,@babylonjs/serializers,@babylonjs/post-processes,@babylonjs/procedural-textures,@babylonjs/viewer,@babylonjs/shared-ui-components,@babylonjs/addons,@babylonjs/accessibility,@babylonjs/ktx2decoder,@babylonjs/smart-filters,@babylonjs/smart-filters-blocks,@babylonjs/lottie-player",
        "build:es6:tools": "nx run-many --outputStyle=static --target=build --parallel --maxParallel=2 --projects=@babylonjs/node-editor,@babylonjs/node-geometry-editor,@babylonjs/node-render-graph-editor,@babylonjs/node-particle-editor,@babylonjs/inspector-legacy,@babylonjs/gui-editor,@tools/smart-filters-editor-control,@tools/smart-filters-debugger,@tools/smart-filters-editor,@babylonjs/inspector,@babylonjs/mcp-servers",
        "watch:shaders": "build-tools -c build-shaders --global --watch",
        "watch:assets": "build-tools -c pa --global --watch",
        "watch:assets:smart-filters": "npm run build:assets:smart-filters:prerequisites && node ./packages/dev/smartFilters/dist/utils/buildTools/watchShaders.js ./packages/dev/smartFilterBlocks/src/blocks smart-filters core",
        "watch:source:dev": "tsc -b ./tsconfig.devpackages.json -w",
        "watch:source:smart-filters": "tsc -b ./tsconfig.smartFilters.json -w",
        "build:assets": "build-tools -c pa --global",
        "build:assets:smart-filters:prerequisites": "tsc -p packages/dev/smartFilters/tsconfig.buildTools.json --noCheck",
        "build:assets:smart-filters": "npm run build:assets:smart-filters:prerequisites && node ./packages/dev/smartFilters/dist/utils/buildTools/buildShaders.js ./packages/dev/smartFilterBlocks/src/blocks smart-filters core",
        "build:shaders": "build-tools -c build-shaders --global",
        "watch:dev": "npx build-tools -c dw -wa -wd",
        "watch:dev:skip-compile": "npx build-tools -c dw -wa -wd -sc",
        "build:babylonjs": "nx build babylonjs",
        "build:tools": "npm run build -w @dev/build-tools && npm run build -w eslint-plugin-babylonjs && npm run build:snippet-loader",
        "build:test-tools": "npm run build -w @tools/test-tools",
        "build:snippet-loader": "npm run build -w @tools/snippet-loader",
        "test": "vitest run --project=unit",
        "test:unit": "npm run build:assets:smart-filters && vitest run --project=unit",
        "test:visualization": "playwright test -c ./playwright.config.ts",
        "test:visualization:ui": "playwright test -c ./playwright.config.ts --ui",
        "test:visualization:devhost": "playwright test -c ./playwright.devhost.config.ts",
        "test:visualization:devhost:ui": "playwright test -c ./playwright.devhost.config.ts --ui",
        "test:integration": "playwright test -c ./playwright.config.ts --project=integration && npm run test -w @tools/memory-leak-tests",
        "test:memory-leaks": "npm run test -w @tools/memory-leak-tests",
        "test:memory-leaks:unit": "npm run test:unit -w @tools/memory-leak-tests",
        "test:memory-leaks:all": "npm run test:all -w @tools/memory-leak-tests",
        "test:memory-leaks:packages": "npm run test:packages -w @tools/memory-leak-tests",
        "test:performance": "playwright test -c ./playwright.config.ts --project=performance",
        "test:interactions": "playwright test -c ./playwright.config.ts --project=interaction",
        "test:audioV2": "playwright test --project=audioV2",
        "test:graphTools": "playwright test -c ./playwright.config.ts --project=graphTools",
        "test:escheck": "nx run-many --outputStyle=static --target=test:escheck --parallel --maxParallel=6 --exclude=@babylonjs/root",
        "test:es6vis": "npm run test:es6vis -w @tools/tests",
        "test:docs": "node ./scripts/typedoc-generator.mjs",
        "audit:side-effects": "node ./scripts/treeshaking/auditSideEffects.mjs",
        "update:manifest": "node ./scripts/treeshaking/auditSideEffects.mjs --out scripts/treeshaking/side-effects-manifest.json",
        "split:register-class": "node ./scripts/treeshaking/splitRegisterClass.mjs",
        "inject:pure-annotations": "node ./scripts/treeshaking/injectPureAnnotations.mjs",
        "generate:pure-barrels": "node ./scripts/treeshaking/generatePureBarrels.mjs",
        "generate:side-effect-stubs": "node ./scripts/treeshaking/generateSideEffectStubs.mjs",
        "test:treeshaking": "node ./scripts/treeshaking/bundleSmokeTest.mjs --all-packages",
        "check:manifest-drift": "node ./scripts/treeshaking/checkManifestDrift.mjs",
        "check:pure-barrels": "node ./scripts/treeshaking/generatePureBarrels.mjs --check",
        "check:side-effects-sync": "node ./scripts/treeshaking/syncSideEffects.mjs --check --all-packages",
        "check:treeshaking": "node ./scripts/treeshaking/verifyTreeShaking.mjs --all-packages",
        "check:treeshaking-all": "npm run check:treeshaking && npm run check:side-effects-sync && npm run test:treeshaking",
        "catalog:static-helpers": "node ./scripts/treeshaking/catalogStaticHelpers.mjs",
        "prepare": "npm run build:tools && npm i @dev/build-tools -D && npm run build:assets && npm run build:test-tools && node scripts/setupGitHooks.mjs",
        "clean": "npx nx run-many --outputStyle=static --target=clean --all --exclude=@babylonjs/root && npm run build:tools",
        "format": "npm run format:check && npm run format:fix",
        "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx,js,json,scss,css}\"",
        "format:fix": "prettier --write \"packages/**/src/**/*.{ts,tsx,js,json,scss,css}\"",
        "lint": "npm run lint:check",
        "lint:check": "eslint \"packages/**/src/**/*.{ts,tsx,js,json}\" --quiet --cache && npm run check:treeshaking && npm run check:side-effects-sync",
        "lint:changed": "node scripts/lint-changed.mjs",
        "lint:changed:fix": "node scripts/lint-changed.mjs --fix",
        "precommit": "lint-staged --allow-empty",
        "lint:check-ci": "eslint \"packages/**/src/**/*.{ts,tsx,js,json}\" --quiet --format azure-devops && npm run lint:cycles && npm run check:treeshaking && npm run check:side-effects-sync",
        "lint:cycles": "npx --yes dpdm -T --no-tree --exit-code circular:1 \"./packages/dev/core/src/**/*\"",
        "update-all-dependencies": "npm update -ws",
        "prepare-snapshot": "npm run build:snapshot -w @tools/babylon-server && build-tools -c ps",
        "start": "npx nx run-many --targets watch:dev:skip-compile serve --projects @babylonjs/root @tools/babylon-server --parallel 2 --skipNxCache true --outputStyle stream",
        "start:devhost": "npm run serve -w @tools/dev-host"
    },
    "lint-staged": {
        "packages/**/src/**/*.{ts,tsx,js,json}": [
            "prettier --write",
            "eslint --quiet --cache --no-warn-ignored"
        ],
        "packages/**/src/**/*.{scss,css}": "prettier --write"
    },
    "engines": {
        "node": "^20.19.0 || >=22.13.0 <23.0.0 || >=24.0.0 <25.0.0",
        "npm": ">=11.18.0"
    },
    "changelog": {
        "nextVersion": "Unreleased",
        "ignoreCommitters": [],
        "feature": "New Feature"
    },
    "nx": {},
    "overrides": {
        "@babylonjs/lite": "$@babylonjs/lite",
        "eslint-plugin-github": {
            "eslint": "^10.0.0"
        },
        "eslint-plugin-import": {
            "eslint": "^10.0.0"
        },
        "@rollup/plugin-commonjs": {
            "glob": "^13.0.6"
        },
        "rollup-plugin-postcss": {
            "cssnano": "^7.1.9"
        },
        "eslint-plugin-tsdoc": {
            "@typescript-eslint/utils": "^8.58.2"
        },
        "@eslint/compat": {
            ".": "^2.0.0",
            "eslint": "$eslint"
        },
        "dompurify": "3.4.0"
    }
}
