{
    "name": "@tools/sandbox",
    "private": true,
    "version": "1.0.0",
    "files": [
        "dist"
    ],
    "types": "dist/index.d.ts",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "scripts": {
        "build": "npm run clean && npm run compile",
        "build:declaration": "build-tools -c pud --config ./config.json",
        "build:deployment": "npm run clean && vite build",
        "compile": "tsc -b tsconfig.build.json",
        "postcompile": "build-tools -c pa",
        "serve": "vite",
        "serve:prod": "vite build && vite preview",
        "serve:https": "vite --host :: --https",
        "serve:dev": "vite",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@dev/build-tools": "1.0.0",
        "@dev/core": "1.0.0",
        "@dev/loaders": "1.0.0",
        "@dev/inspector": "1.0.0",
        "@types/dagre": "^0.7.47",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0"
    },
    "sideEffects": true
}
