{
    "name": "@tools/babylon-server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "clean": "rimraf dist && rimraf declarations",
        "static-serve": "http-server ",
        "serve": "node scripts/ensureDeclarationBuilds.mjs && node scripts/ensureUmdBuilds.mjs && vite",
        "serve:live": "node scripts/ensureDeclarationBuilds.mjs && node scripts/ensureUmdBuilds.mjs && ENABLE_LIVE_RELOAD=true vite",
        "serve:no-watch": "node scripts/ensureDeclarationBuilds.mjs && node scripts/ensureUmdBuilds.mjs && NO_WATCH=true vite",
        "serve:source": "node scripts/ensureDeclarationBuilds.mjs && node scripts/ensureUmdBuilds.mjs && vite",
        "build": "npm run build:dev",
        "build:dev": "npm run build:declaration",
        "build:prod": "npm run build:declaration",
        "build:snapshot": "npm run clean && npm run build:declaration && vite build --mode production",
        "build:declaration": "build-tools -c pud --config ./declarationConfigDev.json",
        "watch:declaration:dev": "build-tools -c pud --config ./declarationConfigDev.json --watch",
        "prepare": "node ./scripts/generateScripts.js"
    },
    "devDependencies": {
        "@dev/build-tools": "1.0.0",
        "@dev/core": "1.0.0",
        "@tools/snippet-loader": "1.0.0",
        "@dev/addons": "1.0.0",
        "@dev/gui": "1.0.0",
        "@dev/inspector": "1.0.0",
        "@dev/loaders": "1.0.0",
        "@dev/post-processes": "1.0.0",
        "@dev/procedural-textures": "1.0.0",
        "@dev/serializers": "1.0.0",
        "@dev/shared-ui-components": "1.0.0",
        "@tools/node-editor": "1.0.0",
        "@tools/gui-editor": "1.0.0",
        "@tools/ktx2decoder": "1.0.0"
    },
    "sideEffects": true
}
