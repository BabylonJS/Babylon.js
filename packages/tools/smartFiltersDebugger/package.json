{
    "name": "@tools/smart-filters-debugger",
    "private": true,
    "version": "0.1.0",
    "description": "A browser extension to allow for debugging Babylon.js Smart Filters in websites",
    "license": "MIT",
    "readme": "README.md",
    "sideEffects": false,
    "files": [
        "dist",
        "src",
        "license.md",
        "readme.md"
    ],
    "scripts": {
        "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
        "build": "npm run clean && npm run compile",
        "compile": "rollup -c rollup.config.umd.mjs --environment ROLLUP_MODE:production",
        "watch": "rollup -c rollup.config.umd.mjs --watch"
    },
    "devDependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.1.0",
        "@fortawesome/free-solid-svg-icons": "^6.1.0",
        "@fortawesome/react-fontawesome": "^0.2.0",
        "@types/chrome": "^0.0.268",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sass": "^1.62.1",
        "@tools/smart-filters-editor-control": "^1.0.0"
    }
}
