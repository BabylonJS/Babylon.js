{
    "extends": ["../../../tsconfig.build.json", "./tsconfig.viewer.json"],

    "compilerOptions": {
        "outDir": "./dist/tsbuild",
        "rootDir": "./src",
        "composite": true,
        "paths": {
            "core/*": ["public/@babylonjs/core/*"],
            "loaders/*": ["public/@babylonjs/loaders/*"]
        }
    },

    "references": [
        {
            "path": "../../dev/core/tsconfig.build.json"
        },
        {
            "path": "../../dev/loaders/tsconfig.build.json"
        }
    ],

    "include": ["./src/**/*"]
}
