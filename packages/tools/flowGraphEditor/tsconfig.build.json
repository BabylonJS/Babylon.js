{
    "extends": "../../../tsconfig.build.json",

    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "paths": {
            "core/*": ["dev/core/dist/*"],
            "shared-ui-components/*": ["dev/sharedUiComponents/dist/*"],
            "flow-graph-editor/*": ["tools/flowGraphEditor/src/*"],
            "@tools/snippet-loader": ["tools/snippetLoader/dist"]
        }
    },

    "references": [
        {
            "path": "../../dev/core/tsconfig.build.json"
        },
        {
            "path": "../snippetLoader/tsconfig.build.json"
        }
    ],

    "include": ["./src/**/*.ts", "./src/**/*.tsx"]
}
