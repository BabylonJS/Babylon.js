{
    "name": "@tools/smart-filters-editor",
    "private": true,
    "version": "1.0.0",
    "description": "The Smart Filters Editor tool is a web-based tool that allows you to create and edit Smart Filters for Babylon.js.",
    "license": "MIT",
    "scripts": {
        "build": "npm run clean && npm run compile",
        "build:deployment": "npm run clean && vite build",
        "compile": "tsc -b tsconfig.build.json",
        "serve": "vite",
        "serve:prod": "vite build && vite preview",
        "serve:https": "vite --host :: --https",
        "serve:dev": "vite",
        "clean": "rimraf dist && rimraf *.tsbuildinfo -g"
    },
    "devDependencies": {
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@fortawesome/fontawesome-svg-core": "^6.1.0",
        "@fortawesome/free-solid-svg-icons": "^6.1.0",
        "@fortawesome/react-fontawesome": "^0.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sass": "^1.62.0",
        "@dev/core": "^1.0.0",
        "@dev/shared-ui-components": "^1.0.0",
        "@dev/smart-filters": "^1.0.0",
        "@dev/smart-filters-blocks": "^1.0.0",
        "@tools/smart-filters-editor-control": "^1.0.0"
    }
}
