        "children": [
          {
            "name": "box",
            "className": "Rectangle",
            "width": "450px",
            "height": "250px",
            "background": "white",
            "cornerRadius": 12,
            "thickness": 0,
            "children": [
              {
                "name": "icon",
                "className": "TextBlock",
                "text": "⚠️",
