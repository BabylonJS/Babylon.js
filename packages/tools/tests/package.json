{
    "name": "@tools/tests",
    "private": true,
    "version": "1.0.0",
    "types": "dist/index",
    "main": "dist/index",
    "module": "dist/index",
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "test": "vitest run",
        "test:debug": "set DEBUG=true && npm run test",
