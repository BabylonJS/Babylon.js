        "test:playwright": "playwright test --config ../../../playwright.config.ts"
    },
    "devDependencies": {
        "@dev/core": "^1.0.0",
        "@dev/gui": "^1.0.0",
        "@dev/loaders": "^1.0.0",
        "@dev/materials": "^1.0.0",
        "@dev/serializers": "^1.0.0",
        "@dev/shared-ui-components": "^1.0.0",
        "@tools/test-tools": "^1.0.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "sass": "^1.62.1",
        "browserstack-local": "^1.5.5"
    },
    "sideEffects": false
}
