{
    "name": "@dev/core",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "npm run clean && npm run compile",
        "test": "vitest run",
        "clean": "rimraf dist && rimraf tsconfig.build.tsbuildinfo",
        "lint": "npm run lint:check",
        "lint:check": "eslint \"src/**/*.{ts,tsx}\"",
        "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
        "precompile": "npm run compile:assets && node ../../../scripts/treeshaking/auditSideEffects.mjs --out ../../../scripts/treeshaking/side-effects-manifest.json && node ../../../scripts/treeshaking/generatePureBarrels.mjs",
        "compile": "npm run compile:source",
        "compile:source": "tsc -b tsconfig.build.json && node ../../../scripts/treeshaking/injectPureAnnotations.mjs",
        "compile:assets": "build-tools -c process-assets --isCore",
        "watch:assets": "build-tools -c process-assets --isCore --watch",
        "watch:source": "tsc -b tsconfig.build.json -w",
        "watch": "build-tools -c dev-watch --packages \"core\" -wa"
    },
    "sideEffects": [
        "**/*",
        "!**/*.pure.*",
        "!**/pure.ts",
        "!**/pure.js",
        "!src/Maths/ThinMaths/**"
    ],
    "devDependencies": {
        "@dev/build-tools": "^1.0.0",
        "@types/draco3d": "^1.4.3",
        "@types/draco3dgltf": "^1.4.0"
    }
}
