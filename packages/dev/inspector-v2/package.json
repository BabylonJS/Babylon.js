{
    "name": "@dev/inspector",
    "version": "1.0.0",
    "types": "dist/index",
    "main": "dist/index",
    "module": "dist/index",
    "private": true,
    "sideEffects": true,
    "scripts": {
        "build": "npm run clean && npm run compile",
        "test": "vitest run",
        "clean": "rimraf dist && rimraf *.tsbuildinfo -g",
        "compile": "tsc -b tsconfig.build.json",
        "serve": "vite",
        "watch": "tsc -b tsconfig.build.json -w",
        "watch:dev": "npm run watch",
        "makeAvatar": "node scripts/makeAvatar.mjs",
        "babylon-inspector": "node --no-warnings dist/cli/cli.js --bridge-script dist/cli/bridge.js"
    },
    "devDependencies": {
        "@dev/addons": "1.0.0",
        "@dev/core": "1.0.0",
        "@dev/gui": "1.0.0",
        "@dev/loaders": "1.0.0",
        "@dev/materials": "1.0.0",
        "@dev/serializers": "1.0.0",
        "@fluentui-contrib/react-resize-handle": "^0.8.4",
        "@fluentui-contrib/react-virtualizer": "^1.0.0",
        "@fluentui/react-components": "^9.70.0",
        "@fluentui/react-icons": "^2.0.310",
        "@tools/gui-editor": "1.0.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@types/ws": "^8.5.0",
        "gif.js.optimized": "^1.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sharp": "^0.33.0",
        "ws": "^8.18.0"
    },
    "dependencies": {
        "@babylonjs/havok": "^1.3.12"
    }
}
