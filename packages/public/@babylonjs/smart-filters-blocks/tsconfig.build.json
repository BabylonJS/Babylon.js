{
    "extends": "../../../../tsconfig.build.json",

    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "target": "ES2020",
        "importHelpers": true,
        "sourceMap": true,
        "declarationMap": true,
        "inlineSources": false,
        "paths": {
            "core/*": ["public/@babylonjs/core/*"],
            "smart-filters": ["public/@babylonjs/smart-filters/dist"],
            "smart-filters/*": ["public/@babylonjs/smart-filters/dist/*"]
        }
    },

    "include": ["./src/**/*"]
}
