{
    "name": "@babylonjs/gui",
    "version": "9.14.0",
    "main": "index.js",
    "module": "index.js",
    "types": "index.d.ts",
    "files": [
        "**/*.js",
        "**/*.d.ts",
        "**/*.map",
        "readme.md",
        "license.md"
    ],
    "scripts": {
        "build": "npm run clean && npm run compile",
        "clean": "rimraf dist && rimraf *.tsbuildinfo -g && rimraf \"./**/*.!(md|json|build.json)\" -g",
        "compile": "tsc -b tsconfig.build.json && build-tools -c tp --outDir . --buildType es6 --basePackage @babylonjs/gui --appendJS",
        "postcompile": "build-tools -c add-js-to-es6"
    },
    "devDependencies": {
        "@babylonjs/core": "9.14.0",
        "@dev/build-tools": "^1.0.0",
        "@dev/gui": "1.0.0"
    },
    "peerDependencies": {
        "@babylonjs/core": "^9.0.0"
    },
    "keywords": [
        "3D",
        "javascript",
        "html5",
        "webgl",
        "babylon.js"
    ],
    "license": "Apache-2.0",
    "esnext": "index.js",
    "type": "module",
    "sideEffects": [
        "**/index.js",
        "**/*fragment.js",
        "**/fluent.vertex.js",
        "**/fluentBackplate.vertex.js",
        "**/fluentButton.vertex.js",
        "**/handle.vertex.js",
        "3D/materials/mrdl/shaders/*vertex.js",
        "2D/FrameGraph/renderGraphGUIBlock.js",
        "2D/controls/button.js",
        "2D/controls/checkbox.js",
        "2D/controls/colorpicker.js",
        "2D/controls/container.js",
        "2D/controls/control.js",
        "2D/controls/displayGrid.js",
        "2D/controls/ellipse.js",
        "2D/controls/focusableButton.js",
        "2D/controls/gradient/LinearGradient.js",
        "2D/controls/gradient/RadialGradient.js",
        "2D/controls/grid.js",
        "2D/controls/image.js",
        "2D/controls/inputPassword.js",
        "2D/controls/inputText.js",
        "2D/controls/inputTextArea.js",
        "2D/controls/line.js",
        "2D/controls/multiLine.js",
        "2D/controls/radioButton.js",
        "2D/controls/rectangle.js",
        "2D/controls/scrollViewers/scrollViewer.js",
        "2D/controls/sliders/imageBasedSlider.js",
        "2D/controls/sliders/scrollBar.js",
        "2D/controls/sliders/slider.js",
        "2D/controls/stackPanel.js",
        "2D/controls/statics.js",
        "2D/controls/textBlock.js",
        "2D/controls/toggleButton.js",
        "2D/controls/virtualKeyboard.js",
        "3D/materials/fluent/fluentMaterial.js",
        "3D/materials/fluentBackplate/fluentBackplateMaterial.js",
        "3D/materials/fluentButton/fluentButtonMaterial.js",
        "3D/materials/handle/handleMaterial.js",
        "3D/materials/mrdl/mrdlBackglowMaterial.js",
        "3D/materials/mrdl/mrdlBackplateMaterial.js",
        "3D/materials/mrdl/mrdlFrontplateMaterial.js",
        "3D/materials/mrdl/mrdlInnerquadMaterial.js",
        "3D/materials/mrdl/mrdlSliderBarMaterial.js",
        "3D/materials/mrdl/mrdlSliderThumbMaterial.js"
    ],
    "homepage": "https://www.babylonjs.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/BabylonJS/Babylon.js.git"
    },
    "bugs": {
        "url": "https://github.com/BabylonJS/Babylon.js/issues"
    }
}