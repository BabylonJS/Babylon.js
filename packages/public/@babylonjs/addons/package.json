{
    "name": "@babylonjs/addons",
    "version": "8.53.0",
    "main": "index.js",
    "module": "index.js",
    "types": "index.d.ts",
    "files": [
        "**/*.js",
        "**/*.d.ts",
        "**/*.map",
        "readme.md",
        "license.md",
        "NOTICE.md"
    ],
    "scripts": {
        "build": "npm run clean && npm run compile",
        "clean": "rimraf dist && rimraf *.tsbuildinfo -g && rimraf \"./**/*.!(md|json|build.json|lts.json)\" -g",
        "compile": "swc ../../../dev/addons/src -d ./ --strip-leading-paths --ignore \"**/*.d.ts\" && tsc -p tsconfig.build.json --emitDeclarationOnly && build-tools -c ppp --dir ./ --base-package @babylonjs/addons --append-js"
    },
    "devDependencies": {
        "@babylonjs/core": "8.53.0",
        "@dev/addons": "^1.0.0",
        "@dev/build-tools": "^1.0.0"
    },
    "peerDependencies": {
        "@babylonjs/core": "^8.0.0"
    },
    "keywords": [
        "3D",
        "javascript",
        "html5",
        "webgl",
        "babylon.js"
    ],
    "license": "Apache-2.0",
    "esnext": "index.js",
    "type": "module",
    "sideEffects": true,
    "homepage": "https://www.babylonjs.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/BabylonJS/Babylon.js.git"
    },
    "bugs": {
        "url": "https://github.com/BabylonJS/Babylon.js/issues"
    }
}