{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "bundler",
        "outDir": "./bin",
        "rootDir": "../../../dev/inspector-v2/src/cli",
        "declaration": false,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "paths": {
            "shared-ui-components/*": ["../../../dev/sharedUiComponents/dist/*"]
        }
    },
    "include": ["../../../dev/inspector-v2/src/cli/**/*"]
}
