{
    "name": "babylonjs-inspector",
    "version": "9.6.2",
    "main": "babylon.inspector-v2.bundle.js",
    "files": [
        "babylon.inspector-v2.*",
        "license.md",
        "package.json",
        "readme.md"
    ],
    "scripts": {
        "build": "npm run clean && npm run build:prod && npm run build:declaration",
        "build:dev": "rollup -c rollup.config.umd.mjs",
        "build:dev:fast": "rollup -c rollup.config.umd.mjs --environment ROLLUP_DEVMODE:true",
        "build:prod": "rollup -c rollup.config.umd.mjs --environment ROLLUP_MODE:production",
        "build:declaration": "build-tools -c pud --config ./config.json",
        "clean": "rimraf dist && rimraf babylon*.* -g"
    },
    "dependencies": {
        "babylonjs": "9.6.2",
        "babylonjs-addons": "9.6.2",
        "babylonjs-gui": "9.6.2",
        "babylonjs-gui-editor": "9.6.2",
        "babylonjs-loaders": "9.6.2",
        "babylonjs-materials": "9.6.2",
        "babylonjs-serializers": "9.6.2"
    },
    "devDependencies": {
        "@dev/build-tools": "1.0.0",
        "@dev/inspector": "1.0.0"
    },
    "keywords": [
        "3D",
        "javascript",
        "html5",
        "webgl",
        "babylon.js"
    ],
    "license": "Apache-2.0",
    "sideEffects": true,
    "homepage": "https://www.babylonjs.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/BabylonJS/Babylon.js.git"
    },
    "bugs": {
        "url": "https://github.com/BabylonJS/Babylon.js/issues"
    }
}