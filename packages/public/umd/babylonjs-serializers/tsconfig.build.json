{
    "extends": "../../../../tsconfig.build.json",

    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "../../../",
        "target": "ES5",
        "ignoreDeprecations": "6.0",
        "declaration": false,
        "importHelpers": true,
        "paths": {
            "core/*": ["../../../dev/core/dist/*"],
            "serializers/*": ["../../../dev/serializers/src/*"],
            "@lts/serializers/*": ["../../../lts/serializers/src/*"]
        }
    },
    "include": ["./src/**/*", "../../../dev/serializers/src/**/*", "../../../lts/serializers/src/**/*"]
}
