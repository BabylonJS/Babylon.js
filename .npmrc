node-options=--max-old-space-size=8192

; Supply-chain policy: only install dependency versions published more than 7
; days ago (rolling window). `min-release-age` requires npm >= 11.10. Ignored by
; older clients.
;
; No exclusions: our own monorepo packages (`babylonjs-*`, `@babylonjs/*`) are
; workspace symlinks, so the age filter never applies to them anyway. Every
; genuinely external dependency stays subject to the 7-day gate — including the
; registry-published `@babylonjs/havok` and `@babylonjs/lite`, which live outside
; this monorepo. Do NOT add a `min-release-age-exclude` for them (or a broad
; `@babylonjs/*` glob): that would exempt external code from the supply-chain
; window, which is exactly what this policy exists to prevent.
min-release-age=7