node-options=--max-old-space-size=8192

; Supply-chain policy: only install dependency versions published more than 7
; days ago (rolling window). `min-release-age` requires npm >= 11.10; the
; `min-release-age-exclude` list requires npm >= 11.18. Ignored by older clients.
; Our own packages are exempt so internal releases are not delayed.
min-release-age=7
min-release-age-exclude[]=@babylonjs/*
min-release-age-exclude[]=babylonjs-*